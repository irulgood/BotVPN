cat >/usr/bin/backup_sellvpn <<'EOF'
#!/bin/bash
# File: /usr/bin/backup_sellvpn
# Backup BotVPN dalam 1 file ZIP lalu kirim ke Telegram admin

VARS_FILE="/root/BotVPN/.vars.json"
DB_FOLDER="/root/BotVPN"
BACKUP_DIR="/tmp/botvpn-backup"
TIMESTAMP=$(date +"%Y%m%d-%H%M%S")
ZIP_FILE="$BACKUP_DIR/backup-botvpn-$TIMESTAMP.zip"

mkdir -p "$BACKUP_DIR"
rm -f "$BACKUP_DIR"/backup-botvpn-*.zip

# Cek dependency
if ! command -v jq >/dev/null 2>&1; then
    echo "❌ jq belum terinstall"
    exit 1
fi

if ! command -v zip >/dev/null 2>&1; then
    echo "❌ zip belum terinstall"
    exit 1
fi

# Cek file .vars.json
if [ ! -f "$VARS_FILE" ]; then
    echo "❌ File $VARS_FILE tidak ditemukan"
    exit 1
fi

# Ambil nilai dari .vars.json
BOT_TOKEN=$(jq -r '.BOT_TOKEN // empty' "$VARS_FILE")
USER_ID=$(jq -r '.USER_ID // empty' "$VARS_FILE")

if [ -z "$BOT_TOKEN" ] || [ -z "$USER_ID" ]; then
    echo "❌ BOT_TOKEN atau USER_ID kosong di $VARS_FILE"
    exit 1
fi

cd "$DB_FOLDER" || {
    echo "❌ Folder $DB_FOLDER tidak ditemukan"
    exit 1
}

# Daftar file yang dibackup
BACKUP_FILES=()
for FILE in sellvpn.db trial.db ressel.db; do
    if [ -f "$FILE" ]; then
        BACKUP_FILES+=("$FILE")
        echo "✅ $FILE masuk backup"
    else
        echo "⚠️ $FILE tidak ditemukan, dilewati"
    fi
done

if [ ${#BACKUP_FILES[@]} -eq 0 ]; then
    echo "❌ Tidak ada file database yang bisa dibackup"
    exit 1
fi

zip -q -j "$ZIP_FILE" "${BACKUP_FILES[@]}"

if [ ! -s "$ZIP_FILE" ]; then
    echo "❌ Gagal membuat file ZIP backup"
    exit 1
fi

CAPTION="✅ Backup BotVPN
📦 File: $(basename "$ZIP_FILE")
🕒 Waktu: $(date '+%Y-%m-%d %H:%M:%S WIB')
📄 Isi: ${BACKUP_FILES[*]}"

HTTP_CODE=$(curl -sS --connect-timeout 10 --max-time 120 \
    -w "%{http_code}" -o /tmp/backup_sellvpn_response.json \
    -F chat_id="$USER_ID" \
    -F document=@"$ZIP_FILE" \
    -F caption="$CAPTION" \
    "https://api.telegram.org/bot$BOT_TOKEN/sendDocument")

if [ "$HTTP_CODE" = "200" ]; then
    echo "✅ Backup ZIP terkirim ke Telegram: $ZIP_FILE"
    rm -f "$ZIP_FILE" /tmp/backup_sellvpn_response.json
    exit 0
else
    echo "❌ Gagal kirim backup ZIP ke Telegram. HTTP: $HTTP_CODE"
    cat /tmp/backup_sellvpn_response.json 2>/dev/null || true
    exit 1
fi
EOF

# bikin cron job tiap jam 12 malam
cat >/etc/cron.d/backup_sellvpn <<'EOF'
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
# Backup BotVPN setiap 6 jam: 00:00, 06:00, 12:00, 18:00 WIB
0 */6 * * * root /usr/bin/backup_sellvpn >> /var/log/backup_sellvpn.log 2>&1
EOF

chmod +x /usr/bin/backup_sellvpn
chmod +x /usr/bin/sellvpn
    service cron restart
